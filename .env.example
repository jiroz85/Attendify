# Server
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Postgres
DATABASE_URL=postgresql://root:root123@localhost:5432/attendfy
DB_CONNECTION_LIMIT=10

# JWT
