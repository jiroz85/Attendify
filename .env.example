# Server
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=attendance
DB_CONNECTION_LIMIT=10

# JWT
JWT_ACCESS_SECRET=replace-me-access
JWT_REFRESH_SECRET=replace-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Refresh token storage
REFRESH_TOKEN_PEPPER=replace-me-pepper
REFRESH_TOKEN_MAX_ACTIVE=5
